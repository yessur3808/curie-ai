TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DISCORD_BOT_TOKEN=your_discord_bot_token
WHATSAPP_SESSION_PATH=./whatsapp_session

LLM_MODELS=Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf,Meta-Llama-3-70B-Instruct-Q4_K_M.gguf
CODING_MODEL_NAME=codellama-34b-instruct.Q4_K_M.gguf

# LLM Provider Priority (comma-separated, tried in order)
# Options: anthropic, openai, gemini, llama.cpp
# Default: llama.cpp (local only). Add cloud providers to use them.
# Example: LLM_PROVIDER_PRIORITY=anthropic,openai,gemini,llama.cpp
LLM_PROVIDER_PRIORITY=llama.cpp

# Cloud LLM API Keys (optional — leave blank to use only local models)
# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-3.5-turbo

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Google Gemini
# GOOGLE_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash

# Route simple/short queries to local model even when cloud providers are available
# Set to true to always use cloud for everything (more costs, higher quality)
LLM_CLOUD_SIMPLE_TASKS=false

# LLM Context Window Configuration
# LLM_CONTEXT_SIZE=2048  # Total context window size (default: 2048)
# LLM_CONTEXT_BUFFER=16  # Buffer reserved for system tokens (default: 16)
# LLM_MIN_TOKENS=64  # Minimum tokens required for a response (default: 64)
# LLM_FALLBACK_MAX_TOKENS=512  # Fallback max_tokens if tokenization fails (default: 512)
# LLM_DEFAULT_MAX_TOKENS=128  # Default max_tokens for ask_llm() when not explicitly specified (default: 128)

# Long-conversation summarisation
# HISTORY_SUMMARISE_THRESHOLD=20  # Summarise history when it exceeds this many turns (default: 20)
# HISTORY_KEEP_RECENT=6           # Recent turns to keep verbatim after summarisation (default: 6)

# Info Search Task Configuration
# INFO_SEARCH_TEMPERATURE=0.2  # Temperature for info search LLM calls (default: 0.2, lower for more deterministic results)
# INFO_SEARCH_MAX_TOKENS=512  # Max tokens for info search responses (default: 512, must leave room for prompt in 2048 context)
# INFO_SEARCH_MAX_SOURCES=3  # Maximum number of sources to process (default: 3, prevents context overflow)
# INFO_SEARCH_MAX_SNIPPET_CHARS=400  # Maximum characters per snippet (default: 400, ~100 tokens)

# Voice/Audio Configuration
# WHISPER_MODEL=base  # Whisper model: tiny, base, small, medium, large (default: base)

MASTER_USER_ID=123456789  # <--- Replace with your own user ID

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=assistant_db
POSTGRES_USER=your_pg_user
POSTGRES_PASSWORD=your_pg_password

MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=assistant_db

# Session Management Configuration
# SESSION_SCOPE=per_channel_user  # Options: single, per_user, per_channel_user (default: per_channel_user)
# SESSION_MAX_HISTORY=50          # Max messages to retain per session (default: 50)
# SESSION_COLLECTION=sessions     # MongoDB collection name for sessions (default: sessions)

# GitHub Integration (for code operations and PR management)
GITHUB_TOKEN=ghp_*********************************
MAIN_REPO=https://github.com/johndoe/abc_project
MAIN_REVIEWER=MainCoder_or_yourself
TARGET_BRANCH=main

# GitLab Integration (optional - for GitLab code operations)
# GITLAB_TOKEN=glpat-****************************
# GITLAB_URL=https://gitlab.com  # Or your self-hosted GitLab instance

# Bitbucket Integration (optional - for Bitbucket code operations)
# BITBUCKET_USERNAME=your_username
# BITBUCKET_APP_PASSWORD=your_app_password

# Self-Update Configuration (optional)
# SYSTEMD_SERVICE_NAME=curie-ai  # Systemd service name for automated restarts
# SERVICE_RESTART_TIMEOUT=30  # Timeout in seconds for service restart (default: 30)

# Code Review Configuration (optional)
# CODE_REVIEW_MAX_CHARS=4000  # Maximum characters to read from a file for review (default: 4000)

# Connector Flags - Set which connectors to run
RUN_TELEGRAM=true
RUN_DISCORD=false
RUN_WHATSAPP=false
RUN_API=true
RUN_CODER=false
RUN_CODING_SERVICE=false  # Run standalone coding service in parallel

# Proactive Messaging Configuration
ENABLE_PROACTIVE_MESSAGING=true  # Enable/disable proactive messaging feature (default: true)
PROACTIVE_CHECK_INTERVAL=3600  # How often to check for proactive messages in seconds (default: 3600 = 1 hour)

# Chat Behavior Configuration
MINIMAL_SANITIZATION=true  # Use minimal sanitization for natural chat (default: true). Set to false for aggressive sanitization that removes all code.

# Persona/Assistant Configuration
ASSISTANT_NAME=jarvis  # Display name of your AI assistant
PERSONA_FILE=personality.json  # Persona config filename (or "all" for multi-persona mode)

# Proactive Learning (auto-extract user preferences from conversations)
# ENABLE_LEARNING=true       # Enable/disable proactive learning (default: true)
# LEARNING_MAX_FACTS=50      # Max facts to store per user (default: 50)


PROJECTS_ROOT=/var/projects